# Application
APP_ENV=development

# Database
DATABASE_URL=postgresql+asyncpg://osiris:osiris_dev_pass@localhost:5432/osiris_inventario

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT Security
SECRET_KEY=change-me-in-production-use-a-random-256-bit-key
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Inventory
KARDEX_METHOD=PEPS

# CORS (JSON array of allowed origins)
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# Audit
MAX_EXPORT_DATE_RANGE_DAYS=90
